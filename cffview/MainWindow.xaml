<Window x:Class="cffview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:cffview.ViewModels"
        xmlns:converters="clr-namespace:cffview.Converters"
        mc:Ignorable="d"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Title="CFF View"
        Height="600" Width="400"
        MinHeight="500" MinWidth="350"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:DelayToColorConverter x:Key="DelayToColor"/>
        <converters:TimeFormatConverter x:Key="TimeFormat"/>
        <converters:LineColorConverter x:Key="LineColor"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="DepartureTemplate">
            <Border Margin="0,2" Padding="6" CornerRadius="4" Background="#FAFAFA">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Column="0" Grid.RowSpan="2" 
                            Background="{Binding Line.Color, Converter={StaticResource LineColor}}"
                            CornerRadius="3" Padding="4,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Line.ShortName}" 
                                   FontWeight="Bold" Foreground="White" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Grid.Column="1" Grid.Row="0" 
                               Text="{Binding DisplayTime, Converter={StaticResource TimeFormat}}"
                               FontSize="14" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    
                    <TextBlock Grid.Column="1" Grid.Row="1" 
                               Text="{Binding Destination}" FontSize="11" Foreground="#666"
                               TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                    
                    <StackPanel Grid.Column="2" Grid.RowSpan="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DelayMinutes, StringFormat='+{0} min'}" 
                                   Foreground="{Binding DelayMinutes, Converter={StaticResource DelayToColor}}"
                                   FontSize="10" FontWeight="Medium"
                                   HorizontalAlignment="Right"
                                   Visibility="{Binding IsDelayed, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding Platform}" FontSize="10" Foreground="#999"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteTemplate">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{Binding StopName}" 
                                   FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Content="X" 
                                Command="{Binding DataContext.RemoveFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Background="Transparent" BorderThickness="0" 
                                Foreground="#999" FontSize="12" Cursor="Hand" Padding="4"/>
                    </Grid>
                    
                    <ItemsControl ItemsSource="{Binding Departures}" 
                                  ItemTemplate="{StaticResource DepartureTemplate}"
                                  Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#EE1C25" Padding="12,10">
            <StackPanel>
                <TextBlock Text="CFF View" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Prochains departs" FontSize="11" Foreground="#FFCCCC"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Search Box -->
                <Border Margin="8,8,8,4">
                    <Grid>
                        <TextBox x:Name="SearchBox" 
                                Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource SearchBoxStyle}"
                                GotFocus="SearchBox_GotFocus"
                                LostFocus="SearchBox_LostFocus"
                                TextChanged="SearchBox_TextChanged"
                                KeyDown="SearchBox_KeyDown"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="Rechercher..." 
                                   IsHitTestVisible="False" Foreground="#999" Margin="12,10"/>
                    </Grid>
                </Border>

                <!-- Search Results -->
                <Border Visibility="{Binding ShowSearchResults, Converter={StaticResource BoolToVis}}"
                        Margin="8,0,8,4">
                    <Border Background="White" CornerRadius="6" Padding="4">
                        <ListView x:Name="SearchResultsList" ItemsSource="{Binding SearchResults}" 
                                 BorderThickness="0" MaxHeight="200"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MouseDoubleClick="SearchResultsList_MouseDoubleClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,6">
                                        <TextBlock Text="{Binding Name}" FontSize="13"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Border>

                <!-- Current Departures -->
                <Border Visibility="{Binding ShowDepartures, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Prochains departs" FontSize="14" FontWeight="SemiBold"/>
                            <Button Grid.Column="1" Content="[Favori]" 
                                    Command="{Binding AddFavoriteCommand}"
                                    Background="Transparent" BorderThickness="0" 
                                    Foreground="#EE1C25" FontSize="11" Cursor="Hand"/>
                        </Grid>
                        
                        <ItemsControl ItemsSource="{Binding Departures}" 
                                      ItemTemplate="{StaticResource DepartureTemplate}"
                                      Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Favorites -->
                <ItemsControl ItemsSource="{Binding Favorites}" 
                              ItemTemplate="{StaticResource FavoriteTemplate}"/>

                <!-- No Favorites -->
                <Border Visibility="{Binding Favorites.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                        Margin="20,40" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Aucun favori" FontSize="16" Foreground="#999" HorizontalAlignment="Center"/>
                        <TextBlock Text="Recherchez un arret" FontSize="12" Foreground="#BBB" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Loading -->
                <TextBlock Text="Chargement..." FontSize="12" Foreground="#999" Margin="12"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

                <!-- Error -->
                <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                        Margin="8" Padding="8" Background="#FFEBEE" CornerRadius="4">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontSize="12"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Background="White" Padding="12,6" BorderThickness="0,1,0,0" BorderBrush="#DDD">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Background="Transparent" BorderThickness="0" 
                        FontSize="11" Cursor="Hand" Padding="8,2"/>
            </Grid>
        </Border>
    </Grid>
</Window>