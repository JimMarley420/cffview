<Window x:Class="cffview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:cffview.ViewModels"
        xmlns:converters="clr-namespace:cffview.Converters"
        mc:Ignorable="d"
        Title="CFF View - Horaires Transports Suisses"
        Height="700" Width="450"
        MinHeight="500" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:DelayToColorConverter x:Key="DelayToColor"/>
        <converters:TimeFormatConverter x:Key="TimeFormat"/>
        <converters:LineColorConverter x:Key="LineColor"/>
        <converters:CountToVisibilityConverter x:Key="CountToVis"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="DepartureTemplate">
            <Border Margin="0,4" Padding="8" CornerRadius="6" Background="#FAFAFA">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="{Binding Line.Color, Converter={StaticResource LineColor}}"
                            CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Line.ShortName}" 
                                   FontWeight="Bold" Foreground="White" FontSize="14"/>
                    </Border>
                    
                    <TextBlock Grid.Column="1" Text="{Binding DisplayTime, Converter={StaticResource TimeFormat}}"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0"/>
                    
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Destination}" FontSize="13" 
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Platform}" FontSize="11" Foreground="Gray"
                                   Visibility="{Binding Platform, Converter={StaticResource NullToVis}}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DelayMinutes, StringFormat='+{}{0} min'}" 
                                   Foreground="{Binding DelayMinutes, Converter={StaticResource DelayToColor}}"
                                   FontSize="12" FontWeight="Medium"
                                   Visibility="{Binding IsDelayed, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteTemplate">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding StopName}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StopId}" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                        
                        <Button Grid.Column="1" Content="X" 
                                Command="{Binding DataContext.RemoveFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Background="Transparent" BorderThickness="0" 
                                Foreground="Gray" FontSize="14" Cursor="Hand"/>
                    </Grid>
                    
                    <ItemsControl ItemsSource="{Binding Departures}" 
                                  ItemTemplate="{StaticResource DepartureTemplate}"
                                  Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#EE1C25" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CFF View" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Prochains departs" FontSize="13" Foreground="#FFCCCC"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="4">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#4CAF50"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                        <Setter Property="Fill" Value="#FFC107"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Search Box -->
                <Border Margin="12,12,12,0">
                    <Grid>
                        <TextBox x:Name="SearchBox" 
                                Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource SearchBoxStyle}"
                                GotFocus="SearchBox_GotFocus"
                                LostFocus="SearchBox_LostFocus"
                                TextChanged="SearchBox_TextChanged"
                                KeyDown="SearchBox_KeyDown"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="Rechercher un arret..." 
                                   IsHitTestVisible="False" Foreground="Gray" Margin="14,12"/>
                    </Grid>
                </Border>

                <!-- Search Results -->
                <Border Visibility="{Binding ShowSearchResults, Converter={StaticResource BoolToVis}}"
                        Margin="12,4,12,12">
                    <Border Style="{StaticResource CardStyle}" Padding="0">
                        <ListView ItemsSource="{Binding SearchResults}" 
                                SelectedItem="{Binding SelectedStop}"
                                BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1" Content="+" 
                                                Command="{Binding DataContext.SelectStopCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="#EE1C25" Foreground="White"
                                                BorderThickness="0" Padding="8,2" 
                                                FontWeight="Bold" Cursor="Hand"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Border>

                <!-- Favorites Section -->
                <ItemsControl ItemsSource="{Binding Favorites}" 
                              ItemTemplate="{StaticResource FavoriteTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Current Departures (when no favorites) -->
                <Border Visibility="{Binding ShowDepartures, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Prochains departs" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Departures}" 
                                      ItemTemplate="{StaticResource DepartureTemplate}"/>
                        <Button Content="Ajouter aux favoris" 
                                Command="{Binding AddFavoriteCommand}"
                                Background="#EE1C25" Foreground="White"
                                Padding="16,8" Margin="0,12,0,0"
                                BorderThickness="0" FontWeight="Medium" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- No Favorites placeholder -->
                <Border Visibility="{Binding Favorites.Count, Converter={StaticResource CountToVis}, ConverterParameter=Invert}"
                        Margin="20,40" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Aucun favori" FontSize="18" Foreground="Gray" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Recherchez un arret pour commencer" FontSize="13" 
                                   Foreground="#AAA" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Loading indicator -->
                <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Margin="20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Chargement..." FontSize="14" Foreground="Gray"/>
                    </StackPanel>
                </Border>

                <!-- Error message -->
                <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                        Margin="12" Padding="12" Background="#FFEBEE" CornerRadius="8">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontSize="13"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="{Binding Favorites.Count, StringFormat='{}{0} favori(s)'}" 
                           Foreground="Gray" VerticalAlignment="Center"/>
                
                <Button Grid.Column="1" Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Background="Transparent" BorderThickness="0" 
                        FontSize="14" Cursor="Hand" ToolTip="Rafraichir" Padding="8,4"/>
            </Grid>
        </Border>
    </Grid>
</Window>